# Backend API base URL (no trailing slash).
# When running locally: backend on 3001, frontend on 3000.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: API key for backend /operations and /compliance routes.
# If not set, enter in the Operations page UI.
NEXT_PUBLIC_API_KEY=

# Solana RPC (for wallet connection)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
